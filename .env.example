OPENAI_API_KEY=

# ── GitHub App (SaaS — required for project GitHub Integration) ─────────────
# Create a GitHub App with repository permissions: Contents (read), Pull requests (read), Metadata (read).
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=your-app-slug
# Private key: inline PEM (use \n for newlines) OR path to .pem file
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_PRIVATE_KEY_PATH=
# Setup callback URL registered in GitHub App settings (e.g. https://api.example.com/github/app/setup)
# GITHUB_APP_SETUP_URL=

# Legacy PAT (deprecated — migrate projects to GitHub App)
# GITHUB_TOKEN=

# Webhook HMAC secret (future pull_request webhooks)
# GITHUB_WEBHOOK_SECRET=
# GITHUB_API_BASE=https://api.github.com
# GITHUB_HTTP_TIMEOUT_S=30
# PR_AGENT_EXECUTE_RUNS=0
VITE_API_BASE_URL=https://qa-bot-demoqa.onrender.com

# ── Supabase (backend: JWKS ES256 + service client) ─────────────────────────
# Same project URL as the dashboard (used to fetch JWKS and optional DB client).
SUPABASE_URL=
# Server-only secret (service_role) — required for Supabase REST writes (runs memory, projects, etc.)
# SUPABASE_SERVICE_ROLE_KEY=
# Where catalog projects are stored: auto | supabase | sqlite
#   auto (default): Supabase when SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set, else local SQLite
# VANYA_PROJECTS_BACKEND=auto
# Optional: comma-separated JWT aud values (default: authenticated). Use __skip__ to disable aud check.
# SUPABASE_JWT_AUDIENCES=authenticated
# 1 / true = enforce JWT when SUPABASE_URL is set; 0 = disable (local/CI).
VANYA_AUTH_ENABLED=1
# Optional: comma-separated allowed email domains (empty / unset = any domain).
# Matching is case-insensitive. Example:
# ALLOWED_EMAIL_DOMAINS=fahorro.com.mx,zuperio.com.mx
ALLOWED_EMAIL_DOMAINS=
# Phase 2: machine calls (CI, agents) — optional shared secret header X-Service-Token
VANYA_SERVICE_TOKEN=

# Phase 4A — Local Agent admin API (/local-agents): when set, require header
# X-Vanya-Local-Agent-Register-Key (or X-Service-Token) for register/list/patch/disable.
# Leave unset only for local dev; set in production.
# LOCAL_AGENT_REGISTER_SECRET=

# Phase 4C — local agent Playwright (optional; off by default)
# VANYA_AGENT_BROWSER_ENABLED=1
# VANYA_AGENT_ALLOW_LOCALHOST=1
# VANYA_AGENT_ALLOW_PRIVATE_IPS=1
# VANYA_AGENT_BROWSER_HEADLESS=1
# VANYA_AGENT_BROWSER_TIMEOUT_MS=15000

# Optional: comma-separated hostname suffixes allowed for Playwright goto / explorers (empty = any public host after SSRF checks).
# ALLOWED_TARGET_HOSTS=demoqa.com,herokuapp.com

# ── Rate limiting (in-memory per worker; use Redis later for multi-instance) ─
# RATE_LIMIT_ENABLED=1
# Count/window seconds: defaults chat 20/300, execute 10/300, explorer 5/300
# RATE_LIMIT_CHAT=20/300
# RATE_LIMIT_EXECUTE=10/300
# RATE_LIMIT_EXPLORER=5/300

# ── Run hot cache (process memory only; SQLite history is not TTL-purged) ──
# Unset or 0 = never evict from run_store memory (recommended for reliable /runs polling).
# Set e.g. 86400 only to cap memory on long-lived workers.
# RUNS_TTL_S=0

# ── Supabase Auth (frontend — publishable anon key only) ───────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
